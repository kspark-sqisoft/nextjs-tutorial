{
  "name": "nextjs-tutorial",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "dev:turbo": "next dev --turbopack -p 3000 -H 0.0.0.0",
    "build": "next build",
    "start": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:run": "tsx src/server/db/migrate.ts",
    "db:reset": "docker compose -f compose.dev.yml exec postgres psql -U postgres -d postgres -c 'DROP DATABASE IF EXISTS blog;' -c 'CREATE DATABASE blog;'",
    "db:studio": "drizzle-kit studio --host 0.0.0.0",
    "seed:categories": "tsx scripts/seed-categories.ts",
    "seed:admin": "tsx scripts/seed-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@aws-sdk/s3-request-presigner": "^3.1055.0",
    "@hookform/resolvers": "^5.4.0",
    "@node-rs/argon2": "^2.0.2",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-query": "^5.100.14",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/html": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@trpc/client": "^11.17.0",
    "@trpc/next": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.36.4",
    "jose": "^6.2.3",
    "lucide-react": "^0.460.0",
    "next": "^15.5.18",
    "next-intl": "^3.26.5",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.9",
    "postgres": "^3.4.9",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "slugify": "^1.6.9",
    "superjson": "^2.2.6",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.19.19",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.18",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "packageManager": "pnpm@9.12.3"
}
