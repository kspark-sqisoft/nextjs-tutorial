# ====== Next.js ======
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ====== DB (compose.dev.yml 의 postgres 컨테이너) ======
# 컨테이너 내부에서 접근할 때의 호스트명은 'postgres'. 호스트 OS 에서 직접 접근 시 localhost.
DATABASE_URL=postgres://postgres:postgres@postgres:5432/blog
# 호스트에서 vitest 돌릴 때 사용 (마일스톤 2 부터 활용).
TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/blog

# ====== JWT (마일스톤 3 에서 사용) ======
# 32 글자 이상의 랜덤 문자열로 교체할 것: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-please-change-me-please-32+
JWT_REFRESH_SECRET=change-me-please-change-me-please-32+
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ====== MinIO (compose.dev.yml 의 minio 컨테이너) ======
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=blog
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# 브라우저가 접근할 외부 URL (presigned 다운로드 등).
S3_PUBLIC_URL=http://localhost:9000

# ====== Mail (Mailpit) ======
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM="Blog <no-reply@blog.local>"

# ====== i18n ======
DEFAULT_LOCALE=ko
SUPPORTED_LOCALES=ko,en
