# 개발용 컨테이너: 의존성만 미리 설치하고, 소스는 bind mount 로 갈아끼운다.
FROM node:22-alpine

WORKDIR /app

# Alpine 환경에서 일부 네이티브 모듈(@node-rs/argon2 등) 빌드를 위해 필요할 수 있는 도구.
# corepack 으로 package.json 의 packageManager 필드를 따라 pnpm 을 활성화한다.
RUN apk add --no-cache libc6-compat \
    && corepack enable

# 의존성 설치 캐시 레이어.
COPY package.json pnpm-lock.yaml* ./
# lockfile 이 아직 없을 수도 있어 두 단계 fallback.
RUN pnpm install --frozen-lockfile 2>/dev/null || pnpm install

# 핫리로드는 bind mount 로 가져온 소스를 watch 한다.
# Windows 의 bind mount 는 file system event 가 누락되기도 해서 polling 모드를 켠다.
ENV WATCHPACK_POLLING=true
ENV CHOKIDAR_USEPOLLING=true

EXPOSE 3000
CMD ["pnpm", "dev"]
